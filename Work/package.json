{
  "name": "atherdon-old-newsletter-js-outertemplate",
  "version": "3.9.0",
  "description": "im trying to separate part of our code",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "browser": "dist/index.iife.js",
  "scripts": {
    "bundle": "rollup -c --bundleConfigAsCjs",
    "dev": "rollup -c -w --bundleConfigAsCjs",
    "build": "npm run clean && npm run bundle",
    "build:babel": "babel src -d dist",
    "prepublish": "npm run clean && npm run build",
    "clean": "shx rm -rf ./coverage && shx rm -rf ./dist",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "lint": "eslint -c ./.eslintrc.js --ext .js . --ignore-path ./.eslintignore --resolve-plugins-relative-to .",
    "lint:fix": "eslint --fix -c ./.eslintrc.js --ext .js . --ignore-path ./.eslintignore --resolve-plugins-relative-to .",
    "chmodler": "shx chmod -R 755 ./bash",
    "test": "jest ./tests/unit/ ./tests/integration/ --passWithNoTests",
    "test:all": "jest ./tests/unit/ ./tests/integration/ --passWithNoTests",
    "test:unit": "jest ./tests/unit/ --passWithNoTests",
    "test:integration": "jest ./tests/integration/ --passWithNoTests",
    "test:template": "jest ./tests/integration/template.test.js --passWithNoTests",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepare": "node -e \"process.exit(process.env.CI ? 0 : 1)\" || (cd $(git rev-parse --show-toplevel) && node Work/node_modules/.bin/husky Work/.husky)",
    "upd": "shx chmod +x ./bash/update-packages.sh && ./bash/update-packages.sh"
  },
  "devDependencies": {
    "@babel/cli": "7.19.3",
    "@babel/core": "7.20.2",
    "@babel/eslint-parser": "7.19.1",
    "@babel/plugin-syntax-dynamic-import": "7.8.3",
    "@babel/plugin-transform-modules-commonjs": "7.19.6",
    "@babel/preset-env": "7.20.2",
    "@changesets/cli": "^2.30.0",
    "@rollup/plugin-babel": "6.0.2",
    "@rollup/plugin-commonjs": "23.0.2",
    "@rollup/plugin-node-resolve": "15.0.1",
    "babel-preset-react-app": "10.0.1",
    "chalk": "5.1.2",
    "eslint": "8.28.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-json": "3.1.0",
    "husky": "^9.1.7",
    "jest": "29.3.1",
    "lint-staged": "^16.4.0",
    "madge": "5.0.1",
    "markup-generator": "^2.5.0",
    "prettier": "2.7.1",
    "rollup": "3.4.0",
    "rollup-plugin-includepaths": "0.2.4",
    "rollup-plugin-node-builtins": "2.1.2",
    "rollup-plugin-node-globals": "1.4.0",
    "shx": "0.3.4"
  },
  "author": "Arthur Tkachenko",
  "license": "MIT",
  "private": false,
  "workspaces": [
    "../sub-modules/Typography",
    "../sub-modules/innerComponents",
    "../sub-modules/Miscellaneous"
  ],
  "release": {
    "publishDir": "dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "atherdon-newsletter-js-layouts-body": "^3.2.0",
    "atherdon-newsletter-js-layouts-misc": "^3.0.0",
    "atherdon-newsletter-js-layouts-typography": "^3.1.0",
    "email-template-object": "^0.2.0",
    "html-typography-tags": "^1.3.0",
    "lit-typography": "^0.1.0",
    "lodash": "^4.17.21"
  },
  "optionalDependencies": {
    "fsevents": "*"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix -c ./.eslintrc.js --ignore-path ./.eslintignore --resolve-plugins-relative-to .",
      "prettier --write"
    ]
  }
}
